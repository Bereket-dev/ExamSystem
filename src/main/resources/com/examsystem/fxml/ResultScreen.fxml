<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" minHeight="520" minWidth="720"
    styleClass="dashboard-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.ResultScreenController">
    <center>
        <VBox alignment="CENTER" spacing="16" styleClass="content-area">
            <Label text="Exam Results" styleClass="result-title" />
            <Label fx:id="examNameLabel" text="Exam Name" styleClass="section-title" />
            <Label text="Marks Obtained" styleClass="subsection-title" />
            <Label fx:id="marksLabel" text="0" styleClass="marks-display" />
            <Label text="Out of" styleClass="subsection-title" />
            <Label fx:id="totalMarksLabel" text="0" styleClass="section-title" />
            <Label fx:id="statusLabel" text="Status" styleClass="subsection-title" />
            <Button fx:id="backButton" text="Back to Dashboard" styleClass="btn-secondary" />
        </VBox>
    </center>
</BorderPane>
