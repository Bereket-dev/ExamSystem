<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.SyncChromeController" spacing="0"
    styleClass="sync-chrome-root">
    <!-- Offline banner -->
    <HBox fx:id="offlineBanner" styleClass="offline-banner" alignment="CENTER_LEFT" spacing="10">
        <padding>
            <Insets top="8" right="16" bottom="8" left="16" />
        </padding>
        <Label text="⚠" styleClass="offline-banner-icon" />
        <Label fx:id="offlineBannerLabel" wrapText="true" HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Global status bar (persistent on every screen) -->
    <HBox styleClass="sync-status-bar" alignment="CENTER_LEFT" spacing="14">
        <padding>
            <Insets top="8" right="16" bottom="8" left="16" />
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="sync-status-indicator">
            <Region fx:id="statusDot" styleClass="sync-dot sync-dot-offline" />
            <Label fx:id="connectionStatusLabel" styleClass="sync-status-text" />
        </HBox>
        <Separator orientation="VERTICAL" />
        <Label fx:id="topologyLabel" styleClass="sync-topology" wrapText="true" HBox.hgrow="ALWAYS" />
        <ProgressIndicator fx:id="syncSpinner" prefWidth="20" prefHeight="20" styleClass="sync-spinner" />
        <Button fx:id="syncNowButton" text="Sync" styleClass="btn-sync" minWidth="88" />
        <Button fx:id="syncHistoryButton" text="History" styleClass="btn-neutral" />
    </HBox>

    <!-- Sync details row -->
    <HBox fx:id="syncPanelCard" styleClass="sync-panel" alignment="CENTER_LEFT" spacing="24">
        <padding>
            <Insets top="8" right="16" bottom="8" left="16" />
        </padding>
        <Label fx:id="lastSyncLabel" styleClass="sync-panel-item" />
        <Label fx:id="pendingLabel" styleClass="sync-panel-item" />
        <Label fx:id="databaseSourceLabel" styleClass="sync-panel-item" />
        <Label fx:id="syncModeLabel" styleClass="sync-panel-item" />
        <Label fx:id="operationLabel" styleClass="sync-panel-item" />
    </HBox>
</VBox>
