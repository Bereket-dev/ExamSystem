<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650" prefWidth="900" xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.StudentDashboardController">
    <top>
        <HBox spacing="12" style="-fx-background-color: #2c3e50; -fx-padding: 16;"
            alignment="CENTER_LEFT">
            <Label text="Student Dashboard"
                style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="welcomeLabel" text="Welcome, Student"
                style="-fx-text-fill: white; -fx-font-size: 14;" />
            <Button fx:id="logoutButton" text="Logout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" style="-fx-padding: 20;">
            <Label text="Your Assigned Exams" style="-fx-font-size: 18; -fx-font-weight: bold;" />
            <SplitPane dividerPositions="0.35" prefHeight="540">
                <items>
                    <VBox spacing="10"
                        style="-fx-padding: 10; -fx-background-color: #f4f6f7; -fx-border-color: #dfe6e9; -fx-border-width: 1;">
                        <Label text="Available Exams"
                            style="-fx-font-size: 14; -fx-font-weight: bold;" />
                        <ListView fx:id="examListView" prefHeight="500" />
                    </VBox>
                    <VBox spacing="10"
                        style="-fx-padding: 10; -fx-background-color: #ffffff; -fx-border-color: #dfe6e9; -fx-border-width: 1;">
                        <Label text="Exam Details" style="-fx-font-size: 14; -fx-font-weight: bold;" />
                        <Label fx:id="examNameLabel" text="Select an exam to view details"
                            style="-fx-font-size: 16; -fx-font-weight: bold;" wrapText="true" />
                        <Label fx:id="examSubjectLabel" text="Subject: " wrapText="true" />
                        <Label fx:id="examDateLabel" text="Date: " wrapText="true" />
                        <Label fx:id="examDurationLabel" text="Duration: " wrapText="true" />
                        <Label fx:id="examStatusLabel" text="Status: " wrapText="true" />
                        <Label fx:id="examDescriptionLabel"
                            text="Description will appear when you select an exam." wrapText="true" />
                        <HBox spacing="12" style="-fx-padding: 10 0 0 0;">
                            <Button fx:id="startExamButton" text="Start Exam"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="statusLabel" textFill="#c0392b" wrapText="true" />
                        </HBox>
                    </VBox>
                </items>
            </SplitPane>
        </VBox>
    </center>
</BorderPane>