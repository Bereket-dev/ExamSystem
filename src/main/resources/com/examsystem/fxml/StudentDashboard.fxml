<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" minHeight="520" minWidth="720"
    styleClass="dashboard-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.StudentDashboardController">
    <top>
        <HBox spacing="12" styleClass="app-header" alignment="CENTER_LEFT">
            <Label text="Student Dashboard" styleClass="header-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="welcomeLabel" text="Welcome, Student" styleClass="header-subtitle" />
            <Button fx:id="logoutButton" text="Logout" styleClass="btn-danger" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" styleClass="content-area">
            <Label text="Your Assigned Exams" styleClass="section-title" />
            <SplitPane dividerPositions="0.35" VBox.vgrow="ALWAYS">
                <items>
                    <VBox spacing="10" styleClass="panel-muted">
                        <Label text="Available Exams" styleClass="subsection-title" />
                        <ListView fx:id="examListView" VBox.vgrow="ALWAYS" />
                    </VBox>
                    <VBox spacing="10" styleClass="panel">
                        <Label text="Exam Details" styleClass="subsection-title" />
                        <Label fx:id="examNameLabel" text="Select an exam to view details"
                            styleClass="section-title" wrapText="true" />
                        <Label fx:id="examSubjectLabel" text="Subject: " wrapText="true" />
                        <Label fx:id="examDateLabel" text="Date: " wrapText="true" />
                        <Label fx:id="examDurationLabel" text="Duration: " wrapText="true" />
                        <Label fx:id="examStatusLabel" text="Status: " wrapText="true" />
                        <Label fx:id="examDescriptionLabel"
                            text="Description will appear when you select an exam." wrapText="true" />
                        <HBox spacing="12">
                            <Button fx:id="startExamButton" text="Start Exam" styleClass="btn-primary" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="statusLabel" styleClass="status-error" wrapText="true" />
                        </HBox>
                    </VBox>
                </items>
            </SplitPane>
        </VBox>
    </center>
</BorderPane>
