<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.examsystem.controller.CreateExamController">
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 16;">
            <Label text="Create Exam" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />
        </HBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <TextField fx:id="examNameField" promptText="Exam Name" />
            <TextField fx:id="subjectField" promptText="Subject" />
            <TextArea fx:id="descriptionField" promptText="Description" prefRowCount="3" />
            <HBox spacing="10">
                <TextField fx:id="durationField" promptText="Duration (minutes)" HBox.hgrow="ALWAYS" />
                <TextField fx:id="totalQuestionsField" promptText="Total Questions" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="totalMarksField" promptText="Total Marks" HBox.hgrow="ALWAYS" />
                <TextField fx:id="passingMarksField" promptText="Passing Marks" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="examDateField" promptText="Date (YYYY-MM-DD)" HBox.hgrow="ALWAYS" />
                <TextField fx:id="examTimeField" promptText="Time (HH:MM:SS)" HBox.hgrow="ALWAYS" />
            </HBox>
            <CheckBox fx:id="publishCheckBox" text="Publish immediately" />
            <Label fx:id="statusLabel" textFill="#27ae60" wrapText="true" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" style="-fx-padding: 20;" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" />
            <Button fx:id="saveButton" text="Save Exam" style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
        </HBox>
    </bottom>
</BorderPane>
