<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" minHeight="520" minWidth="720"
    styleClass="dashboard-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.CreateExamController">
    <top>
        <HBox styleClass="app-header">
            <Label text="Create Exam" styleClass="header-title" />
        </HBox>
    </top>
    <center>
        <VBox spacing="12" styleClass="form-grid">
            <TextField fx:id="examNameField" promptText="Exam Name *" />
            <TextField fx:id="subjectField" promptText="Subject *" />
            <TextArea fx:id="descriptionField" promptText="Description" prefRowCount="3" />
            <HBox spacing="10">
                <TextField fx:id="durationField" promptText="Duration (minutes) *" HBox.hgrow="ALWAYS" />
                <TextField fx:id="totalQuestionsField" promptText="Total Questions *" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="totalMarksField" promptText="Total Marks *" HBox.hgrow="ALWAYS" />
                <TextField fx:id="passingMarksField" promptText="Passing Marks *" HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="examDateField" promptText="Date (YYYY-MM-DD)" HBox.hgrow="ALWAYS" />
                <TextField fx:id="examTimeField" promptText="Time (HH:MM:SS)" HBox.hgrow="ALWAYS" />
            </HBox>
            <CheckBox fx:id="publishCheckBox" text="Publish immediately" />
            <Label fx:id="statusLabel" styleClass="status-success" wrapText="true" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" styleClass="content-area" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" styleClass="btn-neutral" />
            <Button fx:id="saveButton" text="Save Exam" styleClass="btn-primary" />
        </HBox>
    </bottom>
</BorderPane>
