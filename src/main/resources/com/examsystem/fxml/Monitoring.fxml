<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.examsystem.controller.MonitoringController">
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 16;">
            <Label text="Live Exam Monitoring" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />
        </HBox>
    </top>
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <Label fx:id="statusLabel" />
            <ListView fx:id="monitoringListView" prefHeight="450" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" style="-fx-padding: 20;" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" />
            <Button fx:id="refreshButton" text="Refresh" style="-fx-background-color: #d35400; -fx-text-fill: white;" />
        </HBox>
    </bottom>
</BorderPane>
