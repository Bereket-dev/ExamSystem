<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" minHeight="520" minWidth="720"
    styleClass="dashboard-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.MonitoringController">
    <top>
        <HBox styleClass="app-header">
            <Label text="Live Exam Monitoring" styleClass="header-title" />
        </HBox>
    </top>
    <center>
        <VBox spacing="12" styleClass="content-area">
            <Label fx:id="statusLabel" styleClass="status-info" />
            <ListView fx:id="monitoringListView" VBox.vgrow="ALWAYS" prefHeight="450" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" styleClass="content-area" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" styleClass="btn-neutral" />
            <Button fx:id="refreshButton" text="Refresh" styleClass="btn-warning" />
        </HBox>
    </bottom>
</BorderPane>
