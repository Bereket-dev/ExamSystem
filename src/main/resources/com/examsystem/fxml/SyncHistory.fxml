<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.SyncHistoryController"
    styleClass="dashboard-root" prefWidth="720" prefHeight="480">
    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT">
            <padding><Insets top="14" right="16" bottom="14" left="16" /></padding>
            <Label text="Sync History" styleClass="header-title" />
        </HBox>
    </top>
    <center>
        <VBox styleClass="content-area" spacing="12">
            <Label text="Synchronization activity log for debugging and monitoring." styleClass="subsection-text" />
            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>
</BorderPane>
