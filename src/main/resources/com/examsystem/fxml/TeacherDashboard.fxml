<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" minHeight="520" minWidth="720"
    styleClass="dashboard-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.TeacherDashboardController">
    <top>
        <HBox spacing="12" styleClass="app-header" alignment="CENTER_LEFT">
            <Label text="Teacher Dashboard" styleClass="header-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="welcomeLabel" text="Welcome" styleClass="header-subtitle" />
            <Button fx:id="logoutButton" text="Logout" styleClass="btn-danger" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" styleClass="content-area">
            <HBox spacing="10">
                <Button fx:id="createExamButton" text="Create Exam" styleClass="btn-primary" />
                <Button fx:id="monitoringButton" text="Live Monitoring" styleClass="btn-warning" />
                <Button fx:id="reportsButton" text="Reports" styleClass="btn-teal" />
            </HBox>
            <Label text="Your Exams" styleClass="section-title" />
            <ListView fx:id="examListView" VBox.vgrow="ALWAYS" prefHeight="400" />
            <Label fx:id="statusLabel" styleClass="status-error" wrapText="true" />
        </VBox>
    </center>
</BorderPane>
