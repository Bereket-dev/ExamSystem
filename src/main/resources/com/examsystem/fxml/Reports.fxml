<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.examsystem.controller.ReportsController">
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 16;">
            <Label text="Exam Reports" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />
        </HBox>
    </top>
    <center>
        <VBox spacing="12" style="-fx-padding: 20;">
            <Label fx:id="summaryLabel" style="-fx-font-weight: bold;" />
            <ListView fx:id="reportListView" prefHeight="420" />
            <Label fx:id="statusLabel" textFill="#16a085" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" style="-fx-padding: 20;" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" />
            <Button fx:id="refreshButton" text="Generate Reports" style="-fx-background-color: #16a085; -fx-text-fill: white;" />
        </HBox>
    </bottom>
</BorderPane>
