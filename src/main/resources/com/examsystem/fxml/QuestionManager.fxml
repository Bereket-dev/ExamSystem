<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.examsystem.controller.QuestionManagerController">
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 16;">
            <Label fx:id="examTitleLabel" text="Question Manager" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.4">
            <items>
                <VBox spacing="8" style="-fx-padding: 10;">
                    <Label text="Existing Questions" style="-fx-font-weight: bold;" />
                    <ListView fx:id="questionListView" prefHeight="500" />
                </VBox>
                <VBox spacing="8" style="-fx-padding: 10;">
                    <TextArea fx:id="questionTextField" promptText="Question text" prefRowCount="3" />
                    <ComboBox fx:id="questionTypeCombo" />
                    <HBox spacing="8">
                        <TextField fx:id="marksField" promptText="Marks" HBox.hgrow="ALWAYS" />
                        <TextField fx:id="sequenceField" promptText="Order" HBox.hgrow="ALWAYS" />
                    </HBox>
                    <Label text="MCQ Options (1-4) / True=1 False=2 for T/F" />
                    <TextField fx:id="option1Field" promptText="Option 1" />
                    <TextField fx:id="option2Field" promptText="Option 2" />
                    <TextField fx:id="option3Field" promptText="Option 3" />
                    <TextField fx:id="option4Field" promptText="Option 4" />
                    <TextField fx:id="correctOptionField" promptText="Correct option number" />
                    <Label fx:id="statusLabel" textFill="#27ae60" wrapText="true" />
                </VBox>
            </items>
        </SplitPane>
    </center>
    <bottom>
        <HBox spacing="10" style="-fx-padding: 20;" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" />
            <Button fx:id="addQuestionButton" text="Add Question" style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
        </HBox>
    </bottom>
</BorderPane>
