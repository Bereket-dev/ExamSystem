<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" minHeight="520" minWidth="720"
    styleClass="dashboard-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.QuestionManagerController">
    <top>
        <HBox styleClass="app-header">
            <Label fx:id="examTitleLabel" text="Question Manager" styleClass="header-title" />
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.4" styleClass="content-area">
            <items>
                <VBox spacing="8" styleClass="panel-muted">
                    <Label text="Existing Questions" styleClass="subsection-title" />
                    <ListView fx:id="questionListView" VBox.vgrow="ALWAYS" />
                </VBox>
                <VBox spacing="8" styleClass="form-grid">
                    <TextArea fx:id="questionTextField" promptText="Question text *" prefRowCount="3" />
                    <ComboBox fx:id="questionTypeCombo" promptText="Question type" maxWidth="Infinity" />
                    <HBox spacing="8">
                        <TextField fx:id="marksField" promptText="Marks *" HBox.hgrow="ALWAYS" />
                    </HBox>
                    <Label text="Options" styleClass="subsection-title" />
                    <VBox spacing="8">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <RadioButton fx:id="option1Radio" />
                            <TextField fx:id="option1Field" promptText="Option A" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <RadioButton fx:id="option2Radio" />
                            <TextField fx:id="option2Field" promptText="Option B" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <RadioButton fx:id="option3Radio" />
                            <TextField fx:id="option3Field" promptText="Option C" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <RadioButton fx:id="option4Radio" />
                            <TextField fx:id="option4Field" promptText="Option D" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    <Label fx:id="statusLabel" styleClass="status-success" wrapText="true" />
                </VBox>
            </items>
        </SplitPane>
    </center>
    <bottom>
        <HBox spacing="10" styleClass="content-area" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" styleClass="btn-neutral" />
            <Button fx:id="updateQuestionButton" text="Update Question" styleClass="btn-warning" />
            <Button fx:id="deleteQuestionButton" text="Delete Question" styleClass="btn-danger" />
            <Button fx:id="addQuestionButton" text="Add Question" styleClass="btn-secondary" />
        </HBox>
    </bottom>
</BorderPane>
