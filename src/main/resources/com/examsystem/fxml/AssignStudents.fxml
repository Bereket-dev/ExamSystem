<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" minHeight="520" minWidth="720"
    styleClass="dashboard-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.AssignStudentsController">
    <top>
        <HBox styleClass="app-header">
            <Label text="Assign Students to Exam" styleClass="header-title" />
        </HBox>
    </top>
    <center>
        <VBox spacing="15" styleClass="content-area" padding="16">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Select Exam:" />
                <ComboBox fx:id="examComboBox" HBox.hgrow="ALWAYS" />
            </HBox>
            <Label text="Select students to assign" styleClass="subsection-title" />
            <ScrollPane fitToWidth="true" fitToHeight="true">
                <content>
                    <VBox fx:id="studentCheckboxContainer" spacing="8" padding="8" />
                </content>
            </ScrollPane>
            <Label fx:id="statusLabel" styleClass="status-error" wrapText="true" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" styleClass="content-area" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" styleClass="btn-neutral" />
            <Button fx:id="assignButton" text="Assign Selected" styleClass="btn-secondary" />
        </HBox>
    </bottom>
</BorderPane>
