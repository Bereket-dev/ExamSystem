<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" minHeight="520" minWidth="720"
    styleClass="dashboard-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.AssignStudentsController">
    <top>
        <HBox styleClass="app-header">
            <Label text="Assign Students to Exam" styleClass="header-title" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" styleClass="form-grid">
            <Label text="Select Exam:" styleClass="subsection-title" />
            <ComboBox fx:id="examComboBox" prefWidth="400" maxWidth="Infinity" />
            <Label text="Select Student:" styleClass="subsection-title" />
            <ListView fx:id="studentListView" prefHeight="350" VBox.vgrow="ALWAYS" />
            <Label fx:id="statusLabel" styleClass="status-success" wrapText="true" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" styleClass="content-area" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" styleClass="btn-neutral" />
            <Button fx:id="assignButton" text="Assign" styleClass="btn-purple" />
        </HBox>
    </bottom>
</BorderPane>
