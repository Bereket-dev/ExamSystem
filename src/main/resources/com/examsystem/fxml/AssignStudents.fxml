<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.examsystem.controller.AssignStudentsController">
    <top>
        <HBox style="-fx-background-color: #2c3e50; -fx-padding: 16;">
            <Label text="Assign Students to Exam" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" style="-fx-padding: 20;">
            <Label text="Select Exam:" />
            <ComboBox fx:id="examComboBox" prefWidth="400" />
            <Label text="Select Student:" />
            <ListView fx:id="studentListView" prefHeight="350" />
            <Label fx:id="statusLabel" textFill="#27ae60" wrapText="true" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" style="-fx-padding: 20;" alignment="CENTER_RIGHT">
            <Button fx:id="backButton" text="Back" />
            <Button fx:id="assignButton" text="Assign" style="-fx-background-color: #8e44ad; -fx-text-fill: white;" />
        </HBox>
    </bottom>
</BorderPane>
