<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650" prefWidth="900" minHeight="520" minWidth="720"
    styleClass="dashboard-root"
    xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.examsystem.controller.ExamScreenController">
    <top>
        <HBox spacing="16" styleClass="app-header" alignment="CENTER_LEFT">
            <Label fx:id="examHeaderLabel" text="Exam" styleClass="header-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="timerLabel" text="Time left: 00:00" styleClass="timer-label" />
        </HBox>
    </top>
    <center>
        <VBox spacing="16" styleClass="content-area">
            <Label fx:id="questionNumberLabel" text="Question 1 of 1" styleClass="subsection-title" />
            <Label fx:id="questionTextLabel" text="Question will appear here"
                styleClass="question-text" wrapText="true" />
            <VBox fx:id="optionsContainer" spacing="12" />
            <TextArea fx:id="shortAnswerField" promptText="Type your answer here..."
                prefRowCount="6" wrapText="true" visible="false" managed="false" />
            <Label fx:id="feedbackLabel" styleClass="status-error" wrapText="true" />
        </VBox>
    </center>
    <bottom>
        <HBox spacing="12" styleClass="content-area" alignment="CENTER_RIGHT">
            <Button fx:id="previousButton" text="Previous" styleClass="btn-neutral" />
            <Button fx:id="saveButton" text="Save" styleClass="btn-secondary" />
            <Button fx:id="nextButton" text="Next" styleClass="btn-neutral" />
            <Button fx:id="submitButton" text="Submit Exam" styleClass="btn-primary" />
        </HBox>
    </bottom>
</BorderPane>
